programa {
  funcao inicio() {
    real nota = 6
    
    se (nota==10){
      
      escreva("conceito A")
    }
    senao se ("nota<9 e nota<8")
      escreva("conceito B")

      senao se ("nota<9 e nota<8")
      escreva("conceito C")

      senao se ("nota<8 e nota<7")
      escreva("conceito D ")

      senao se ("nota<7")
      escreva("reprovado")

  }
}
